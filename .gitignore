*.iml
.DS_Store

# Signing keys and secrets
*.keystore
*.jks
*.pem
*.key
*.p12
.env
*.env.*

# IDE state
.idea/

# Local machine configuration
/local.properties

# Python virtual environments and caches
.venv/
__pycache__/

# Build and tool caches
.gradle/
.kotlin/
build/
captures/
.externalNativeBuild/
.cxx/
target/

# Vendor build scripts must be tracked despite the build/ ignore above
!native/rust/vendor/**/build/

# Vendored BoringSSL C source tree (checked in by cargo vendor but too large for git)
native/rust/vendor/boring-sys/deps/
# Reality patch: SSL_set_client_random added to vendored BoringSSL (tracked individually)
!native/rust/vendor/boring-sys/deps/boringssl/include/openssl/ssl.h
!native/rust/vendor/boring-sys/deps/boringssl/ssl/internal.h
!native/rust/vendor/boring-sys/deps/boringssl/ssl/handshake_client.cc
!native/rust/vendor/boring-sys/deps/boringssl/ssl/ssl_lib.cc

# Generated documentation artifacts
docs/manual-assets/
docs/*.pdf

# Lefthook local overrides
.lefthook-local.yml

# Repo-local automation artifacts
.ralph/
ralph.yml
hats.yml
PROMPT.md
/specs/
.worktrees/
.claude/worktrees/
.claude/settings.json
security-audit-report.*
.omc/
docs/superpowers/

# Test artifact: adaptive tuning state written by soak tests with random ephemeral ports
native/rust/crates/ripdpi-monitor/adaptive-tuning-v1.json
native/rust/crates/ripdpi-bench/adaptive-tuning-v1.json

# Detekt baselines are forbidden — violations must be fixed in code
detekt-baseline.xml
